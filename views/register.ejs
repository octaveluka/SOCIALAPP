<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <div class="auth-container">
        <div class="auth-visual">
            <div class="auth-visual-content">
                <i class="fa-solid fa-circle-nodes brand-icon"></i>
                <h2>Rejoins la communauté dès aujourd'hui</h2>
                <p>Crée ton profil, partage tes idées et reste connecté avec les personnes qui comptent.</p>

                <div class="auth-visual-features">
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-user-plus"></i>
                        Inscription gratuite et rapide
                    </div>
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-newspaper"></i>
                        Publie et interagis avec ton fil
                    </div>
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-bolt"></i>
                        Notifications en temps réel
                    </div>
                </div>
            </div>
        </div>

        <div class="auth-form-side">
            <div class="auth-card">
                <div class="auth-logo">
                    <i class="fa-solid fa-circle-nodes"></i>
                    <span>SocialApp</span>
                </div>

                <h2>Créer un compte</h2>
                <p class="auth-subtitle">Rejoins la communauté dès maintenant</p>

                <% if (error && error.length > 0) { %>
                    <div class="alert alert-error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span><%= error[0] %></span>
                    </div>
                <% } %>

                <form action="/register" method="POST">
                    <div class="form-group">
                        <label>Nom complet</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-user"></i>
                            <input type="text" name="nom" placeholder="Ton nom" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Adresse e-mail</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-envelope"></i>
                            <input type="email" name="email" placeholder="exemple@email.com" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Mot de passe</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-lock"></i>
                            <input type="password" name="motDePasse" placeholder="6 caractères minimum" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Confirmer le mot de passe</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-lock"></i>
                            <input type="password" name="confirmMotDePasse" placeholder="••••••••" required>
                        </div>
                    </div>

                    <button type="submit" class="btn">
                        <i class="fa-solid fa-user-plus"></i>
                        Créer mon compte
                    </button>
                </form>

                <div class="auth-footer">
                    Déjà un compte ? <a href="/login">Connecte-toi</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>