// =============================================
// APPEND GROUP MESSAGE
// =============================================
function appendGroupMessage(data,isTemp=false){
  const isOwn=(data.expediteur===currentUserId)||(data.expediteur&&data.expediteur._id===currentUserId);
  const wrapper=document.createElement("div");
  wrapper.className=`message-group-wrapper ${isOwn?"sent-wrapper":"received-wrapper"}`;wrapper.dataset.id=data._id;
  if(isTemp) wrapper.dataset.temp="true";
  let html="";

  // Nom affiché (chaos/anon)
  const isChaosName=isChaosActive&&chaosMap[isOwn?currentUserId:(data.expediteur?._id||data.expediteur)];
  const displayName=isChaosActive&&isChaosName?chaosMap[data.expediteur?._id||data.expediteur]?.name:(data.pseudo||data.expediteur?.nom||"?");
  const displayAvatar=data.anonymousAvatar||(isChaosActive&&isChaosName?chaosMap[data.expediteur?._id||data.expediteur]?.avatar:null);

  if(!isOwn&&data.expediteur){
    html+=`<div class="message-author">`;
    if(displayAvatar) html+=`<img src="${displayAvatar}" style="width:18px;height:18px;border-radius:50%;margin-right:4px;" alt="">`;
    html+=esc(displayName)+`</div>`;
  }

  if(data.image){
    const isSticker=data.isSticker;
    html+=`<div class="message-bubble ${isSticker?"sticker-bubble":"img-bubble"} ${isOwn?"sent":"received"}">
      <div class="message-image">
        <img src="${data.image}" alt="" class="${isSticker?"sticker-img":"chat-img"}">
        ${!isSticker?`<a href="${data.image}" download class="img-download-btn" title="Télécharger"><i class="fa-solid fa-download"></i></a>`:""}
      </div>
    </div>`;
  } else if(data.audio){
    let dur="0:00";if(data.duration){const m=Math.floor(data.duration/60),s=String(Math.floor(data.duration%60)).padStart(2,'0');dur=m+":"+s;}
    html+=`<div class="message-bubble audio ${isOwn?"sent":"received"}" data-audio="${data.audio}">
      <div class="audio-wrapper"><button class="play-btn"><i class="fa-solid fa-play"></i></button>
        <div class="waveform"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
        <span class="duration">${dur}</span></div>
      <audio class="audio-player" src="${data.audio}" preload="metadata"></audio>
    </div>`;
  } else {
    const isBurn=data.expiresAt;
    html+=`<div class="message-bubble ${isOwn?"sent":"received"} ${isBurn?"burn-msg":""}">`;
    if(data.repondA){const rc=typeof data.repondA==="object"?(data.repondA.image?"[Image]":(data.repondA.contenu||"").slice(0,50)):(data.repondA||"").slice(0,50);html+=`<div class="reply-quote"><i class="fa-solid fa-reply"></i> ${esc(rc)}</div>`;}
    html+=`<div class="message-text">${formatMentions(esc(data.contenu||""))}</div>`;
    if(isBurn) html+=`<div class="burn-timer" data-expires="${data.expiresAt}">🔥 …</div>`;
    html+=`</div>`;
  }
  html+=`<div class="message-reactions"></div>
    <div class="message-toolbar">
      <button class="toolbar-btn react-btn"><i class="fa-regular fa-face-smile"></i></button>
      <button class="toolbar-btn reply-btn"><i class="fa-solid fa-reply"></i></button>
      ${isOwn?'<button class="toolbar-btn delete-group-btn"><i class="fa-solid fa-trash"></i></button>':""}
    </div>
    <div class="emoji-picker"><span data-emoji="👍">👍</span><span data-emoji="❤️">❤️</span><span data-emoji="😂">😂</span><span data-emoji="😮">😮</span><span data-emoji="😢">😢</span><span data-emoji="🙏">🙏</span></div>`;

  wrapper.innerHTML=html;
  chatMessages.appendChild(wrapper);
  chatMessages.scrollTop=chatMessages.scrollHeight;

  // Burn timer
  const burnEl=wrapper.querySelector(".burn-timer");
  if(burnEl&&data.expiresAt) startBurnTimer(burnEl,data.expiresAt);
}

// =============================================
// BURN TIMER
// =============================================
function startBurnTimer(el,expiresAt){
  const interval=setInterval(()=>{
    const rem=Math.max(0,Math.floor((new Date(expiresAt)-Date.now())/1000));
    el.textContent=`🔥 ${rem}s`;if(rem<=0)clearInterval(interval);
  },1000);
}

// =============================================
// AUDIO PLAYER
// =============================================
function playAudio(element){
  if(!element) return;
  const player=element.querySelector(".audio-player");const btn=element.querySelector(".play-btn i");if(!player) return;
  if(player.paused){
    document.querySelectorAll(".audio-player").forEach(a=>{if(a!==player){a.pause();a.currentTime=0;const p=a.closest(".message-bubble.audio");if(p){p.classList.remove("playing");const b=p.querySelector(".play-btn i");if(b)b.className="fa-solid fa-play";}}});
    player.play();element.classList.add("playing");if(btn)btn.className="fa-solid fa-pause";
  }else{player.pause();element.classList.remove("playing");if(btn)btn.className="fa-solid fa-play";}
  player.onended=()=>{element.classList.remove("playing");if(btn)btn.className="fa-solid fa-play";};
}
document.querySelectorAll(".message-bubble.audio .audio-player").forEach(a=>{
  a.onloadedmetadata=function(){const el=a.closest(".message-bubble.audio")?.querySelector(".duration");if(el&&a.duration&&!isNaN(a.duration)){const m=Math.floor(a.duration/60),s=String(Math.floor(a.duration%60)).padStart(2,'0');el.textContent=m+":"+s;}};
});

function renderBadges(badges){if(!badges||!badges.length)return'';const cfg={verifie:{icon:"fa-check",label:"Vérifié",cls:"badge-verifie"},moderateur:{icon:"fa-shield",label:"Modérateur",cls:"badge-moderateur"},fondateur:{icon:"fa-star",label:"Membre fondateur",cls:"badge-fondateur"},premium:{icon:"fa-crown",label:"Premium",cls:"badge-premium"},staff:{icon:"fa-screwdriver-wrench",label:"Staff",cls:"badge-staff"}};let h='';badges.forEach(b=>{const c=cfg[b.type];if(!c)return;h+=`<span class="badge-tooltip" data-label="${c.label}"><span class="user-badge ${c.cls}"><i class="fa-solid ${c.icon}"></i></span></span>`;});return h;}
function escapeHtml(str){const d=document.createElement("div");d.innerText=str||"";return d.innerHTML;}
function esc(s){return escapeHtml(s);}
function formatMentions(str){return str.replace(/@(\w+)/g,'<span class="mention">@$1</span>');}
document.addEventListener("click",e=>{
  if(!e.target.closest(".emoji-picker")&&!e.target.closest(".react-btn")){document.querySelectorAll(".emoji-picker.active").forEach(p=>p.classList.remove("active"));}
  if(!e.target.closest("#mentionList")&&!e.target.closest("#messageInput")){const ml=document.getElementById("mentionList");if(ml)ml.style.display="none";}
  if(!e.target.closest("#subProfilePanel")&&!e.target.closest("#subProfileBtn")){document.getElementById("subProfilePanel").style.display="none";}
  if(!e.target.closest("#watchPartyPanel")&&!e.target.closest("#watchPartyBtn")){/* keep open */}
  if(!e.target.closest("#voiceRoomPanel")&&!e.target.closest("#voiceRoomBtn")){/* keep open */}
});

<% if (group.systemGroupKey === 'primes') { %>
// === CHARGEMENT TÂCHES JOURNALIÈRES ===
(async function loadPrimesTasks(){
  const container=document.getElementById("tasksContainer");
  if(!container)return;
  try{
    const res=await fetch("/api/daily-tasks",{credentials:"same-origin"});
    if(!res.ok){container.innerHTML=`<p style="text-align:center;color:var(--text-secondary)">Erreur ${res.status}</p>`;return;}
    const data=await res.json();
    if(!data.success||!data.tasks||!data.tasks.length){container.innerHTML='<p style="text-align:center;color:var(--text-secondary);font-size:13px;">Aucune tâche disponible pour aujourd\'hui.</p>';return;}
    container.innerHTML="";
    data.tasks.forEach(t=>{
      const card=document.createElement("div");
      card.className="task-card"+(t.done?" task-done":"");
      card.dataset.id=t._id;
      card.innerHTML=`
        <div class="task-info">
          <div class="task-title">${t.title}</div>
          <div class="task-desc">${t.description}</div>
        </div>
        <span class="task-reward">+${t.reward} crédits</span>
        <div class="task-actions">
          ${t.done
            ? '<span class="task-status-done">✅</span>'
            : `<button class="btn-verify" onclick="verifyTask('${t._id}',this)">Vérifier</button>
               <button class="btn-claim" onclick="claimTask('${t._id}',this)" style="display:none">Valider</button>`
          }
        </div>`;
      container.appendChild(card);
    });
  }catch(e){container.innerHTML='<p style="color:red;text-align:center;font-size:12px;">Erreur de chargement des tâches</p>';}
})();

async function verifyTask(id,btn){
  btn.disabled=true;btn.textContent="Vérification…";
  try{
    const res=await fetch(`/api/daily-tasks/${id}/verify`,{method:"POST",headers:{"Content-Type":"application/json"},credentials:"same-origin"});
    const data=await res.json();
    if(data.already){btn.disabled=true;btn.textContent="Déjà réclamé";return;}
    if(data.verified){
      btn.textContent="✅ Validé";btn.disabled=true;
      const card=btn.closest(".task-card");
      const claimBtn=card.querySelector(".btn-claim");
      if(claimBtn){claimBtn.style.display="inline-flex";}
    }else{
      btn.disabled=false;btn.textContent="Vérifier";
      alert("❌ Tâche non accomplie. Complète-la d'abord !");
    }
  }catch(e){btn.disabled=false;btn.textContent="Vérifier";}
}

async function claimTask(id,btn){
  btn.disabled=true;btn.textContent="…";
  try{
    const res=await fetch(`/api/daily-tasks/${id}/claim`,{method:"POST",headers:{"Content-Type":"application/json"},credentials:"same-origin"});
    const data=await res.json();
    if(data.success){
      const card=btn.closest(".task-card");
      card.classList.add("task-done");
      card.querySelector(".task-actions").innerHTML='<span class="task-status-done">✅</span>';
    }else{btn.disabled=false;btn.textContent="Valider";}
  }catch(e){btn.disabled=false;btn.textContent="Valider";}
}

// === CHARGEMENT PRIMES ACTIVES ===
async function loadBounties(){
  const c=document.getElementById("bountiesContainer");
  if(!c)return;
  try{
    const res=await fetch("/api/bounties/active",{credentials:"same-origin"});
    const data=await res.json();
    if(!data.success||!data.bounties||!data.bounties.length){
      c.innerHTML='<p style="text-align:center;color:var(--text-secondary);font-size:13px;">Aucune prime active pour le moment.</p>';return;
    }
    c.innerHTML="";
    data.bounties.forEach(b=>{
      const div=document.createElement("div");
      div.className="bounty-mini-card";
      div.innerHTML=`
        <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:4px;">
          <span style="font-size:12px;font-weight:700;color:var(--text-primary);">${b.title}</span>
          <span style="font-size:12px;font-weight:700;color:#f59e0b;">💰 ${b.rewardAmount}</span>
        </div>
        <div style="font-size:11px;color:var(--text-secondary);margin-bottom:8px;">Par ${b.creatorNom} • ${b.applicantsCount} candidat(s)</div>
        ${!b.isOwn&&!b.alreadyApplied
          ?`<button class="btn-accomplish-mini" data-id="${b._id}" style="width:100%;padding:6px;border:none;border-radius:6px;background:var(--primary);color:#fff;cursor:pointer;font-size:12px;font-weight:600;">⚡ Accomplir</button>`
          :b.alreadyApplied?'<span style="font-size:11px;color:#10b981;font-weight:600;">✅ Déjà accompli</span>':''
        }`;
      c.appendChild(div);
    });
    c.querySelectorAll(".btn-accomplish-mini").forEach(btn=>{
      btn.addEventListener("click",async()=>{
        btn.disabled=true;btn.textContent="Vérification…";
        try{
          const r=await fetch(`/api/bounties/${btn.dataset.id}/accomplish`,{method:"POST",credentials:"same-origin"});
          const d=await r.json();
          if(d.ok){btn.textContent=`✅ +${d.reward} crédits`;btn.style.background="#10b981";}
          else{btn.disabled=false;btn.textContent="⚡ Accomplir";alert("❌ "+d.reason);}
        }catch(e){btn.disabled=false;btn.textContent="⚡ Accomplir";}
      });
    });
  }catch(e){c.innerHTML='<p style="color:red;text-align:center;font-size:12px;">Erreur primes</p>';}
}
loadBounties();

// === ADMIN : Créer une prime depuis le groupe ===
<% if (isAdmin || isSiteAdmin) { %>
const _createBtn=document.getElementById("createPrimeBtnGroup");
const _adminForm=document.getElementById("adminBountyForm");
if(_createBtn&&_adminForm){
  _createBtn.addEventListener("click",()=>{
    _adminForm.style.display=_adminForm.style.display==="none"?"block":"none";
  });
  document.getElementById("cancelAdminBounty").addEventListener("click",()=>{_adminForm.style.display="none";});
  document.getElementById("submitAdminBounty").addEventListener("click",async()=>{
    const actionType=document.getElementById("adminActionType").value;
    const rewardAmount=parseInt(document.getElementById("adminRewardAmount").value);
    if(!actionType)return alert("Choisis une action.");
    if(!rewardAmount||rewardAmount<1)return alert("Montant invalide.");
    const sbtn=document.getElementById("submitAdminBounty");
    sbtn.disabled=true;sbtn.textContent="Création…";
    try{
      const r=await fetch("/api/bounties",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({actionType,rewardAmount}),credentials:"same-origin"});
      const d=await r.json();
      sbtn.disabled=false;sbtn.textContent="Créer";
      if(d.success){_adminForm.style.display="none";document.getElementById("adminActionType").value="";document.getElementById("adminRewardAmount").value="";loadBounties();}
      else{alert(d.error);}
    }catch(e){sbtn.disabled=false;sbtn.textContent="Créer";}
  });
}
<% } %>

