let watchMode = "solo"; // "solo" | "sync"
let watchBlobUrl = null; // référence au blob URL local pour pouvoir le révoquer

// === Mode toggle ===
document.querySelectorAll(".watch-mode-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    watchMode = btn.dataset.mode;
