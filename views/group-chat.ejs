      watchMode === "sync" ? "👥 Mode Groupe — les membres seront synchronisés" : "👤 Mode Solo — lecture personnelle uniquement";
    document.getElementById("watchPartyStatus").style.display = "block";
  });
});

// === Utilitaire : convertir URL en embed ===
function getYoutubeEmbedUrl(url) {
  try {
    const u = new URL(url);
    if (u.hostname.includes("youtube.com") || u.hostname.includes("youtu.be")) {
      let videoId = u.hostname === "youtu.be" ? u.pathname.slice(1) : (u.searchParams.get("v") || (u.pathname.startsWith("/embed/") ? u.pathname.split("/embed/")[1] : null));
      if (videoId) return `https://www.youtube.com/embed/${videoId}?autoplay=1&enablejsapi=1`;
    }
    if (u.hostname.includes("twitch.tv")) {
      const ch = u.pathname.split("/").filter(Boolean)[0];
      if (ch) return `https://player.twitch.tv/?channel=${ch}&parent=${location.hostname}&autoplay=true`;
    }
  } catch(e) {}
  return null;
}

// === Charger une source dans le player ===
function loadWatchSource(src, isLocalFile=false, syncMode=watchMode) {
  const container = document.getElementById("watchPlayerContainer");
  const iframe = document.getElementById("watchIframe");
  const video = document.getElementById("watchVideo");
  const status = document.getElementById("watchPartyStatus");
  container.style.display = "block";
  const embedUrl = getYoutubeEmbedUrl(src);
  if (embedUrl && !isLocalFile) {
    iframe.src = embedUrl;
    iframe.style.display = "block";
    video.style.display = "none";
    video.src = "";
    status.textContent = syncMode === "sync" ? "▶ YouTube/Twitch — synchronisé avec le groupe 👥" : "▶ YouTube/Twitch — lecture solo 👤";
  } else {
    video.src = src;
    video.style.display = "block";
    iframe.style.display = "none";
    iframe.src = "";
    video.play().catch(()=>{});
    status.textContent = isLocalFile ? "▶ Fichier local — lecture solo uniquement 👤" : (syncMode === "sync" ? "▶ Vidéo MP4 — synchronisée avec le groupe 👥" : "▶ Vidéo MP4 — lecture solo 👤");
  }
  status.style.display = "block";
}

// === Fermer et tout nettoyer ===
function closeWatchParty() {
  document.getElementById("watchPartyPanel").style.display = "none";
  const video = document.getElementById("watchVideo");
  video.pause();
  video.src = "";
  document.getElementById("watchIframe").src = "";
  document.getElementById("watchPlayerContainer").style.display = "none";
  document.getElementById("watchPartyStatus").style.display = "none";
  document.getElementById("watchUrlInput").value = "";
  document.getElementById("watchFileName").textContent = "";
  document.getElementById("watchFileInput").value = "";
  document.getElementById("watchSyncWarning").style.display = "none";
  if (watchBlobUrl) {
    URL.revokeObjectURL(watchBlobUrl);
    watchBlobUrl = null;
  }
}

document.getElementById("watchPartyBtn").addEventListener("click", () => {
  const p = document.getElementById("watchPartyPanel");
  p.style.display = p.style.display === "none" ? "block" : "none";
});
document.getElementById("closeWatchBtn").addEventListener("click", closeWatchParty);

// === Charger depuis URL ===
document.getElementById("watchLoadBtn").addEventListener("click", () => {
  const url = document.getElementById("watchUrlInput").value.trim();
  if (!url) return;
  // Libérer ancien blob si existant
  if (watchBlobUrl) { URL.revokeObjectURL(watchBlobUrl); watchBlobUrl = null; }
  document.getElementById("watchSyncWarning").style.display = "none";
  document.getElementById("watchFileName").textContent = "";
  loadWatchSource(url, false, watchMode);
  if (watchMode === "sync") {
    socket.emit("watch-party-sync", { groupId, action: "load", url });
  }
});

// === Upload d'un fichier local ===
document.getElementById("watchFileInput").addEventListener("change", function() {
  const file = this.files[0];
  if (!file) return;
  if (watchBlobUrl) { URL.revokeObjectURL(watchBlobUrl); watchBlobUrl = null; }
  watchBlobUrl = URL.createObjectURL(file);
  document.getElementById("watchFileName").textContent = file.name;
  document.getElementById("watchUrlInput").value = "";
  // Fichier local = toujours solo
  if (watchMode === "sync") {
    document.getElementById("watchSyncWarning").style.display = "block";
  }
  loadWatchSource(watchBlobUrl, true, "solo");
});

// === Synchronisation vidéo directe (MP4) avec le groupe ===
const watchVideo = document.getElementById("watchVideo");
let watchSyncEnabled = true;
watchVideo.addEventListener("play", () => {
  if (watchMode !== "sync" || !watchSyncEnabled || watchBlobUrl) return;
  socket.emit("watch-party-sync", { groupId, action: "play", currentTime: watchVideo.currentTime });
});
watchVideo.addEventListener("pause", () => {
  if (watchMode !== "sync" || !watchSyncEnabled || watchBlobUrl) return;
  socket.emit("watch-party-sync", { groupId, action: "pause", currentTime: watchVideo.currentTime });
});
watchVideo.addEventListener("seeked", () => {
  if (watchMode !== "sync" || watchBlobUrl) return;
  socket.emit("watch-party-sync", { groupId, action: "seek", currentTime: watchVideo.currentTime });
});

// === Réception synchro depuis le groupe ===
socket.on("watch-party-sync", data => {
  if (data.from === currentUserId) return;
  if (data.url && data.action === "load") {
    document.getElementById("watchPartyPanel").style.display = "block";
    document.getElementById("watchUrlInput").value = data.url;
    loadWatchSource(data.url, false, "sync");
  }
  if (data.action === "play" && watchVideo.style.display !== "none") {
    watchSyncEnabled = false;
    watchVideo.currentTime = data.currentTime;
    watchVideo.play().catch(()=>{}).finally(()=>{ watchSyncEnabled = true; });
  }
  if (data.action === "pause" && watchVideo.style.display !== "none") {
    watchSyncEnabled = false;
    watchVideo.currentTime = data.currentTime;
    watchVideo.pause();
    watchSyncEnabled = true;
  }
  if (data.action === "seek" && watchVideo.style.display !== "none") {
    watchVideo.currentTime = data.currentTime;
  }
});

// === Révoquer le blob si l'utilisateur quitte la page ===
window.addEventListener("beforeunload", () => {
  if (watchBlobUrl) URL.revokeObjectURL(watchBlobUrl);
});


