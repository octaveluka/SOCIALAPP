<!DOCTYPE html>
<html lang="fr">
<head><%- include('partials/head') %></head>
<body class="chat-page">
<%- include('partials/navbar', { currentPage: 'messages' }) %>

<div class="main-container chat-main-container">
  <div class="chat-page-container" id="chatPageContainer">

    <!-- HEADER GROUPE -->
    <div class="chat-header">
      <a href="/messages" class="chat-back"><i class="fa-solid fa-arrow-left"></i></a>
      <img src="<%= group.photo %>" alt="" id="groupHeaderPhoto">
      <div style="flex:1;min-width:0;overflow:hidden;">
        <div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:600;font-size:15px;"><%= group.nom %></div>
        <div style="font-size:11px;font-weight:400;color:var(--text-secondary);"><%= group.membres.length %> membre(s)</div>
      </div>
      <div style="flex-shrink:0;display:flex;gap:6px;align-items:center;">
        <!-- Voice Room -->
        <button id="voiceRoomBtn" title="Salon vocal" class="chat-icon-btn" style="color:var(--text-secondary);"><i class="fa-solid fa-microphone-lines"></i></button>
        <!-- Watch Party -->
        <button id="watchPartyBtn" title="Watch Party" class="chat-icon-btn" style="color:var(--text-secondary);"><i class="fa-solid fa-film"></i></button>
        <!-- SubProfile -->
        <button id="subProfileBtn" title="Profil anonyme" class="chat-icon-btn" style="color:var(--text-secondary);"><i class="fa-solid fa-mask"></i></button>
        <!-- Settings -->
        <a href="/groups/<%= group._id %>/settings" class="chat-icon-btn" style="color:var(--text-secondary);"><i class="fa-solid fa-gear"></i></a>
      </div>
    </div>

    <!-- CHAOS MODE BANNER -->
    <div id="chaosBanner" class="chaos-banner" style="display:none;">
      🎭 <strong>Chaos Mode actif !</strong> Tout le monde est anonymisé. <span id="chaosCountdown"></span>
      <% if (isAdmin) { %><button id="stopChaosBtn" style="margin-left:12px;background:white;border:none;border-radius:6px;padding:4px 10px;cursor:pointer;font-size:12px;">Arrêter</button><% } %>
    </div>

    <!-- VOICE ROOM PANEL -->
    <div id="voiceRoomPanel" class="voice-room-panel" style="display:none;">
      <div class="voice-room-header">
        <i class="fa-solid fa-microphone-lines"></i> Salon Vocal
        <span id="voiceRoomCount">0 membre(s)</span>
        <button id="joinVoiceBtn" class="btn-voice-join">Rejoindre</button>
        <button id="leaveVoiceBtn" class="btn-voice-leave" style="display:none;">Quitter</button>
      </div>
      <div id="voiceRoomMembers" class="voice-room-members"></div>
      <div id="localAudioStatus" style="font-size:12px;color:var(--text-secondary);padding:4px 8px;display:none;">🎤 Micro actif</div>
    </div>

    <!-- FOCUS MODE PANEL -->
    <div id="focusPanel" class="focus-panel" style="display:none;">
      <div class="focus-panel-header">
        <span>📝 Éditeur collaboratif</span>
        <button id="closeFocusBtn" style="background:none;border:none;cursor:pointer;font-size:16px;">✕</button>
      </div>
      <textarea id="focusEditor" placeholder="Écris ici… synchronisé en temps réel avec les membres du groupe"></textarea>
    </div>

    <!-- WATCH PARTY PANEL -->
    <div id="watchPartyPanel" class="watch-party-panel" style="display:none;">
      <div class="watch-party-header">
        <span>🎬 Watch Party</span>
        <button id="closeWatchBtn" style="background:none;border:none;cursor:pointer;font-size:16px;">✕</button>
      </div>
      <div style="display:flex;gap:8px;padding:8px;">
        <input type="text" id="watchUrlInput" placeholder="URL de la vidéo (mp4, youtube...)" style="flex:1;padding:8px;border:1px solid var(--border);border-radius:8px;font-size:13px;">
        <button id="watchLoadBtn" class="btn-primary-action" style="padding:8px 16px;">Charger</button>
      </div>
      <video id="watchVideo" controls style="width:100%;max-height:250px;background:#000;display:none;"></video>
    </div>

    <!-- SUBPROFILE PANEL -->
    <div id="subProfilePanel" class="subprofile-panel" style="display:none;">
      <div class="subprofile-header">
        <span>🎭 Profils anonymes</span>
        <button id="closeSubProfileBtn" style="background:none;border:none;cursor:pointer;">✕</button>
      </div>
      <div id="subProfileList"></div>
      <button id="createSubProfileBtn" class="btn-primary-action" style="margin:12px;width:calc(100% - 24px);">+ Créer un profil anonyme</button>
    </div>

    <% if (group.systemGroupKey === 'primes') { %>
    <!-- PRIMES TASKS PANEL -->
    <div class="primes-panel" id="primesPanel">
      <div class="primes-header">
        <h3>🏆 Tâches Journalières</h3>
        <p>Accomplis des missions pour gagner des crédits • Se renouvèle chaque jour à minuit</p>
      </div>
      <div id="tasksContainer">
        <div style="text-align:center;padding:20px;color:var(--text-secondary);">
          <i class="fa-solid fa-spinner fa-spin"></i> Chargement des tâches…
        </div>
      </div>
    </div>
    <% } %>

    <!-- MESSAGES -->
    <div class="chat-messages" id="chatMessages" <% if (group.systemGroupKey === 'primes') { %>style="display:none"<% } %>>
      <% messages.forEach(msg => {
        const expediteurId = msg.expediteur ? msg.expediteur._id.toString() : ''
        const isOwn = expediteurId === currentUserId
        const pseudo = msg.anonymousName || pseudoMap[expediteurId] || (msg.expediteur ? msg.expediteur.nom : 'Inconnu')
        const isDeleted = msg.isDeleted
        const isBurn = msg.expiresAt
      %>
        <div class="message-group-wrapper <%= isOwn ? 'sent-wrapper' : 'received-wrapper' %>" data-id="<%= msg._id %>">
          <% if (!isOwn && msg.expediteur) { %>
            <div class="message-author">
              <% if (msg.anonymousAvatar) { %><img src="<%= msg.anonymousAvatar %>" style="width:18px;height:18px;border-radius:50%;margin-right:4px;" alt=""><% } %>
              <%= pseudo %>
              <% if (!msg.anonymousName) { %><%- include('partials/badges', { badges: msg.expediteur.badges || [] }) %><% } %>
            </div>
          <% } %>

          <% if (isDeleted) { %>
            <div class="message-bubble deleted-msg <%= isOwn ? 'sent' : 'received' %>">
              <span class="deleted-text"><i class="fa-solid fa-ban"></i> Ce message a été supprimé</span>
            </div>
          <% } else if (msg.audio) { %>
            <div class="message-bubble audio <%= isOwn ? 'sent' : 'received' %>" data-id="<%= msg._id %>" data-audio="<%= msg.audio %>">
              <div class="audio-wrapper">
                <button class="play-btn"><i class="fa-solid fa-play"></i></button>
                <div class="waveform"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
                <span class="duration"><%= msg.duration ? Math.floor(msg.duration/60)+':'+String(Math.floor(msg.duration%60)).padStart(2,'0') : '0:00' %></span>
              </div>
              <audio class="audio-player" src="<%= msg.audio %>" preload="metadata"></audio>
            </div>
          <% } else if (msg.image) { %>
            <div class="message-bubble <%= msg.isSticker ? 'sticker-bubble' : 'img-bubble' %> <%= isOwn ? 'sent' : 'received' %>">
              <% if (msg.repondA && msg.repondA.contenu) { %>
                <div class="reply-quote"><i class="fa-solid fa-reply"></i> <%= (msg.repondA.contenu||'').slice(0,50) %></div>
              <% } %>
              <div class="message-image">
                <img src="<%= msg.image %>" alt="" class="<%= msg.isSticker ? 'sticker-img' : 'chat-img' %>">
                <% if (!msg.isSticker) { %>
                  <a href="<%= msg.image %>" download class="img-download-btn" title="Télécharger"><i class="fa-solid fa-download"></i></a>
                <% } %>
              </div>
            </div>
          <% } else { %>
            <div class="message-bubble <%= isOwn ? 'sent' : 'received' %> <%= isBurn ? 'burn-msg' : '' %> <%= msg.isCodeBlock ? 'code-block-msg' : '' %>">
              <% if (msg.repondA) { %>
                <div class="reply-quote"><i class="fa-solid fa-reply"></i>
                  <% if (typeof msg.repondA === 'object' && msg.repondA.image) { %><i class="fa-solid fa-image"></i> Image
                  <% } else { %><%= typeof msg.repondA === 'object' ? (msg.repondA.contenu||'').slice(0,50) : '' %>
                  <% } %>
                </div>
              <% } %>
              <% if (msg.isCodeBlock) { %>
                <pre class="code-content"><code><%= msg.contenu %></code></pre>
                <% if (msg.codeSignature) { %><div class="code-signature"><i class="fa-solid fa-signature"></i> <%= msg.codeSignature %></div><% } %>
              <% } else { %>
                <div class="message-text"><%= msg.contenu %></div>
              <% } %>
              <% if (isBurn) { %><div class="burn-timer" data-expires="<%= msg.expiresAt %>">⏳ …</div><% } %>
            </div>
          <% } %>

          <% if (!isDeleted) { %>
            <% if (msg.reactions && msg.reactions.length > 0) { %>
              <div class="message-reactions">
                <% const gr={};msg.reactions.forEach(r=>{gr[r.emoji]=(gr[r.emoji]||0)+1}) %>
                <% Object.keys(gr).forEach(emoji=>{ %><span class="reaction-pill"><%= emoji %> <%= gr[emoji] %></span><% }) %>
              </div>
            <% } else { %>
              <div class="message-reactions"></div>
            <% } %>
            <div class="message-toolbar">
              <button class="toolbar-btn react-btn" title="Réagir"><i class="fa-regular fa-face-smile"></i></button>
              <button class="toolbar-btn reply-btn" title="Répondre"><i class="fa-solid fa-reply"></i></button>
              <% if (isOwn) { %>
                <button class="toolbar-btn delete-group-btn" title="Supprimer"><i class="fa-solid fa-trash"></i></button>
              <% } %>
            </div>
            <div class="emoji-picker">
              <span data-emoji="👍">👍</span><span data-emoji="❤️">❤️</span><span data-emoji="😂">😂</span>
              <span data-emoji="😮">😮</span><span data-emoji="😢">😢</span><span data-emoji="🙏">🙏</span>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>

    <% if (group.systemGroupKey !== 'primes') { %>
    <!-- REPLY PREVIEW -->
    <div class="reply-preview" id="replyPreview" style="display:none;">
      <div class="reply-preview-content"><i class="fa-solid fa-reply"></i><span id="replyPreviewText"></span></div>
      <button id="cancelReply"><i class="fa-solid fa-xmark"></i></button>
    </div>

    <!-- IA HINT -->
    <div id="aiCommandHint" class="ai-command-hint" style="display:none;"></div>

    <!-- FORMULAIRE -->
    <form class="chat-input" id="chatForm" onsubmit="return false;">
      <button type="button" id="photoBtn" class="chat-icon-btn" title="Photo"><i class="fa-solid fa-image"></i></button>
      <input type="file" id="photoInput" accept="image/*" style="display:none;">
      <button type="button" id="codeBtn" class="chat-icon-btn" title="Signer du code" style="color:var(--text-secondary);"><i class="fa-solid fa-code"></i></button>
      <% if (isAdmin) { %>
        <button type="button" id="chaosModeBtn" class="chat-icon-btn" title="Chaos Mode" style="color:var(--text-secondary);"><i class="fa-solid fa-wand-magic-sparkles"></i></button>
      <% } %>
      <input type="text" id="messageInput" placeholder="Écrire… (@ mention, /+ IA)" autocomplete="off">
      <button type="button" id="microBtn" class="chat-icon-btn"><i class="fa-solid fa-microphone"></i></button>
      <button type="button" id="sendBtn" class="chat-send-btn" style="display:none;"><i class="fa-solid fa-paper-plane"></i></button>
    </form>
    <!-- BARRE ENREGISTREMENT WHATSAPP -->
    <div id="recordingBar" class="wa-recording-bar" style="display:none;">
      <button type="button" id="cancelRecordBtn" class="wa-rec-cancel"><i class="fa-solid fa-trash"></i></button>
      <div class="wa-rec-center">
        <span class="wa-rec-dot"></span>
        <span id="waTimer" class="wa-rec-timer">0:00</span>
        <div class="wa-rec-wave">
          <span></span><span></span><span></span><span></span><span></span>
          <span></span><span></span><span></span><span></span><span></span>
        </div>
      </div>
      <button type="button" id="sendRecordBtn" class="wa-rec-send"><i class="fa-solid fa-paper-plane"></i></button>
    </div>
    <div class="mention-list" id="mentionList" style="display:none;"></div>
    <% } %>
  </div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const currentUserId = "<%= currentUserId %>";
const groupId = "<%= group._id %>";
const isAdmin = <%= isAdmin %>;
const membres = [<% group.membres.forEach(m => { %>{id:"<%= m.user._id %>",pseudo:"<%= pseudoMap[m.user._id.toString()] %>"},<% }) %>];
let replyingTo = null, mediaRecorder = null, audioChunks = [], isRecording = false, recordingTimer = null, recordingSeconds = 0;
let chaosMap = {}, isChaosActive = false, chaosTimer = null;
let inVoiceRoom = false, localStream = null, peerConnections = {};
let isFocusMode = false, activeSubProfile = null;

let socket;
if (window.notificationSocket) { socket = window.notificationSocket; }
else { socket = io({ query: { userId: currentUserId } }); window.notificationSocket = socket; }

const chatMessages = document.getElementById("chatMessages");
const messageInput = document.getElementById("messageInput");
const sendBtn = document.getElementById("sendBtn");
const microBtn = document.getElementById("microBtn");
const replyPreview = document.getElementById("replyPreview");
const replyPreviewText = document.getElementById("replyPreviewText");
const cancelReply = document.getElementById("cancelReply");
const mentionList = document.getElementById("mentionList");
const aiHint = document.getElementById("aiCommandHint");
const chatPageContainer = document.getElementById("chatPageContainer");

socket.emit("join-group", groupId);
chatMessages.scrollTop = chatMessages.scrollHeight;

// Init burn timers
document.querySelectorAll(".burn-timer").forEach(el => {
  if (el.dataset.expires) startBurnTimer(el, el.dataset.expires);
});

// =============================================
// INPUT HANDLING (skipped for read-only groups like Primes)
// =============================================
if (messageInput) {
messageInput.addEventListener("input", function() {
  const val = this.value;
  const hasText = val.trim().length > 0;
  microBtn.style.display = hasText ? "none" : "flex";
  sendBtn.style.display = hasText ? "flex" : "none";

  // IA hint
  const cmds = {"/+":"🤖 IA Copilot","/imagine":"🎨 Génère une image","/edit":"✏️ Édite image (reply)","/sticker":"🎭 Sticker","/find":"🔍 Recherche","/burn":"🔥 Message éphémère","/summary":"📋 Résumé de la conv","/send":"💸 Transfert /send @pseudo montant","/roll":"🎲 Dés"};
  let hint = null;
  for (const [cmd,desc] of Object.entries(cmds)) { if (val.startsWith(cmd)){hint=desc;break;} }
  if (hint){aiHint.textContent=hint;aiHint.style.display="block";}else{aiHint.style.display="none";}

  // Mentions
  const match = val.match(/@(\w*)$/);
  if (match) {
    const search = match[1].toLowerCase();
    const filtered = membres.filter(m => m.pseudo.toLowerCase().startsWith(search) && m.id !== currentUserId);
    if (filtered.length) {
      mentionList.innerHTML = filtered.map(m => `<div class="mention-item" data-pseudo="${m.pseudo}">@${m.pseudo}</div>`).join("");
      mentionList.style.display = "block";
    } else { mentionList.style.display = "none"; }
  } else { mentionList.style.display = "none"; }
});

mentionList.addEventListener("click", e => {
  const item = e.target.closest(".mention-item"); if (!item) return;
  const pseudo = item.dataset.pseudo;
  const before = messageInput.value.slice(0, messageInput.selectionStart).replace(/@(\w*)$/, "@" + pseudo + " ");
  messageInput.value = before + messageInput.value.slice(messageInput.selectionStart);
  mentionList.style.display = "none"; messageInput.focus();
});

// =============================================
// SEND
// =============================================
function sendMessage() {
  const contenu = messageInput.value.trim(); if (!contenu) return;
  messageInput.value = ""; microBtn.style.display="flex"; sendBtn.style.display="none";
  aiHint.style.display = "none";
  socket.emit("send-group-message", { from:currentUserId, groupId, contenu, repondA: replyingTo?.messageId||null, type:"text" });
  cancelReplyAction();
}
sendBtn.addEventListener("click", sendMessage);
chatForm.addEventListener("submit", e => { e.preventDefault(); sendMessage(); });
document.getElementById("chatForm").addEventListener("keydown", e => { if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();sendMessage();} });

// =============================================
// PHOTO
// =============================================
document.getElementById("photoBtn").addEventListener("click", () => document.getElementById("photoInput").click());
document.getElementById("photoInput").addEventListener("change", async function(e) {
  const file = e.target.files[0]; if (!file) return;
  if (file.size > 5*1024*1024){alert("5 Mo max.");return;}
  const fd = new FormData(); fd.append("image",file); fd.append("groupId",groupId);
  const res = await fetch("/messages/photo",{method:"POST",body:fd});
  const data = await res.json(); if (!data.success) alert(data.error);
  this.value = "";
});

// =============================================
// AUDIO (WhatsApp style)
// =============================================
const recordingBar = document.getElementById("recordingBar");
const waTimerEl = document.getElementById("waTimer");
let pendingAudioBlob = null, pendingAudioDuration = 0, waStream = null;

function showRecordingBar() {
  document.getElementById("chatForm").style.display = "none";
  recordingBar.style.display = "flex";
  waTimerEl.textContent = "0:00";
}
function hideRecordingBar() {
  recordingBar.style.display = "none";
  document.getElementById("chatForm").style.display = "flex";
}

microBtn.addEventListener("click", async function() {
  if (isRecording) { mediaRecorder.stop(); return; }
  try {
    waStream = await navigator.mediaDevices.getUserMedia({audio:true});
    mediaRecorder = new MediaRecorder(waStream,{mimeType:"audio/webm"}); audioChunks=[]; recordingSeconds=0;
    showRecordingBar();
    recordingTimer = setInterval(()=>{recordingSeconds++;const m=Math.floor(recordingSeconds/60),s=String(recordingSeconds%60).padStart(2,'0');waTimerEl.textContent=m+":"+s;},1000);
    mediaRecorder.ondataavailable=e=>audioChunks.push(e.data);
    mediaRecorder.onstop=()=>{clearInterval(recordingTimer);waStream?.getTracks().forEach(t=>t.stop());const blob=new Blob(audioChunks,{type:"audio/webm"});pendingAudioBlob=blob;pendingAudioDuration=recordingSeconds;isRecording=false;};
    mediaRecorder.start(); isRecording=true;
  } catch(e){alert("Impossible d'accéder au microphone.");}
});

document.getElementById("cancelRecordBtn").addEventListener("click",()=>{
  if(mediaRecorder&&isRecording){isRecording=false;mediaRecorder.stop();}
  clearInterval(recordingTimer); waStream?.getTracks().forEach(t=>t.stop());
  pendingAudioBlob=null; pendingAudioDuration=0; hideRecordingBar();
});

document.getElementById("sendRecordBtn").addEventListener("click",()=>{
  if(mediaRecorder&&isRecording){
    mediaRecorder.onstop=()=>{clearInterval(recordingTimer);waStream?.getTracks().forEach(t=>t.stop());const blob=new Blob(audioChunks,{type:"audio/webm"});sendGroupAudio(blob,recordingSeconds);audioChunks=[];isRecording=false;pendingAudioBlob=null;hideRecordingBar();};
    mediaRecorder.stop();
  } else if(pendingAudioBlob){
    sendGroupAudio(pendingAudioBlob,pendingAudioDuration);pendingAudioBlob=null;pendingAudioDuration=0;hideRecordingBar();
  }
});
async function sendGroupAudio(blob,duration){
  const fd=new FormData();fd.append("audio",blob,"audio.webm");fd.append("groupId",groupId);fd.append("duration",duration);
  const res=await fetch("/messages/audio",{method:"POST",body:fd});
  const data=await res.json();if(!data.success)console.error(data.error);
}

// =============================================
// CODE SIGNING
// =============================================
document.getElementById("codeBtn").addEventListener("click", () => {
  const code = prompt("Colle ton code à signer :");
  if (!code || !code.trim()) return;
  messageInput.value = "[CODE]\n" + code.trim();
  microBtn.style.display="none"; sendBtn.style.display="flex";
  messageInput.dataset.isCode = "true";
  messageInput.focus();
});
} // end if(messageInput)

// =============================================
// CHAOS MODE
// =============================================
const chaosModeBtn = document.getElementById("chaosModeBtn");
if (chaosModeBtn) {
  chaosModeBtn.addEventListener("click", () => {
    const mins = parseInt(prompt("Durée du Chaos Mode en minutes (1-60) :", "5"));
    if (!mins || mins < 1 || mins > 60) return;
    socket.emit("start-chaos-mode", { groupId, durationMinutes: mins });
  });
}
const stopChaosBtn = document.getElementById("stopChaosBtn");
if (stopChaosBtn) {
  stopChaosBtn.addEventListener("click", () => { socket.emit("stop-chaos-mode", { groupId }); });
}
socket.on("chaos-mode-started", data => {
  if (data.groupId !== groupId) return;
  chaosMap = data.chaosMap; isChaosActive = true;
  document.getElementById("chaosBanner").style.display = "flex";
  let secs = data.durationMinutes * 60;
  chaosTimer = setInterval(() => {
    secs--;
    const m=Math.floor(secs/60),s=String(secs%60).padStart(2,'0');
    const el=document.getElementById("chaosCountdown"); if(el) el.textContent=`(${m}:${s})`;
    if (secs<=0){clearInterval(chaosTimer);isChaosActive=false;document.getElementById("chaosBanner").style.display="none";}
  },1000);
});
socket.on("chaos-mode-ended", data => {
  if (data.groupId!==groupId) return;
  isChaosActive=false; chaosMap={};
  document.getElementById("chaosBanner").style.display="none";
  clearInterval(chaosTimer);
});

// =============================================
// VOICE ROOM
// =============================================
document.getElementById("voiceRoomBtn").addEventListener("click", () => {
  const panel = document.getElementById("voiceRoomPanel");
  panel.style.display = panel.style.display==="none" ? "block" : "none";
  if (panel.style.display==="block") loadVoiceMembers();
});
async function loadVoiceMembers() {
  const res = await fetch(`/api/groups/${groupId}/voice/members`);
  const data = await res.json();
  updateVoicePanel(data.members||[]);
}
function updateVoicePanel(members) {
  document.getElementById("voiceRoomCount").textContent = members.length + " membre(s)";
  document.getElementById("voiceRoomMembers").innerHTML = members.map(m =>
    `<div class="voice-member"><img src="${m.photoProfil||m.photo||'https://ui-avatars.com/api/?name=?'}" alt=""><span>${m.nom||m.name||"?"}</span></div>`
  ).join("");
}
document.getElementById("joinVoiceBtn").addEventListener("click", async () => {
  try {
    localStream = await navigator.mediaDevices.getUserMedia({audio:true});
    const res = await fetch(`/api/groups/${groupId}/voice/join`,{method:"POST"});
    const data = await res.json();
    if(data.success){
      inVoiceRoom=true;
      document.getElementById("joinVoiceBtn").style.display="none";
      document.getElementById("leaveVoiceBtn").style.display="inline-flex";
      document.getElementById("localAudioStatus").style.display="block";
      updateVoicePanel(data.members||[]);
    }
  } catch(e){alert("Impossible d'accéder au microphone.");}
});
document.getElementById("leaveVoiceBtn").addEventListener("click", async () => {
  if(localStream){localStream.getTracks().forEach(t=>t.stop());localStream=null;}
  Object.values(peerConnections).forEach(pc=>pc.close());peerConnections={};
  await fetch(`/api/groups/${groupId}/voice/leave`,{method:"POST"});
  inVoiceRoom=false;
  document.getElementById("joinVoiceBtn").style.display="inline-flex";
  document.getElementById("leaveVoiceBtn").style.display="none";
  document.getElementById("localAudioStatus").style.display="none";
});
socket.on("voice-room-update", data => {
  if(data.groupId!==groupId) return;
  loadVoiceMembers();
  if(inVoiceRoom&&data.action==="join"&&data.userId!==currentUserId) initiateCall(data.userId);
});
socket.on("voice-offer", async data => {
  if(!inVoiceRoom||!localStream) return;
  const pc = createPeerConnection(data.from);
  await pc.setRemoteDescription(new RTCSessionDescription(data.offer));
  const answer = await pc.createAnswer();
  await pc.setLocalDescription(answer);
  socket.emit("voice-answer",{to:data.from,from:currentUserId,answer,groupId});
});
socket.on("voice-answer", async data => {
  const pc=peerConnections[data.from]; if(pc) await pc.setRemoteDescription(new RTCSessionDescription(data.answer));
});
socket.on("voice-ice", data => {
  const pc=peerConnections[data.from]; if(pc) pc.addIceCandidate(new RTCIceCandidate(data.candidate)).catch(()=>{});
});
function createPeerConnection(peerId){
  const pc=new RTCPeerConnection({iceServers:[{urls:"stun:stun.l.google.com:19302"}]});
  peerConnections[peerId]=pc;
  if(localStream) localStream.getTracks().forEach(t=>pc.addTrack(t,localStream));
  pc.onicecandidate=e=>{if(e.candidate)socket.emit("voice-ice",{to:peerId,candidate:e.candidate,groupId});};
  pc.ontrack=e=>{const audio=document.createElement("audio");audio.srcObject=e.streams[0];audio.autoplay=true;document.body.appendChild(audio);};
  return pc;
}
async function initiateCall(peerId){
  const pc=createPeerConnection(peerId);
  const offer=await pc.createOffer();
  await pc.setLocalDescription(offer);
  socket.emit("voice-offer",{to:peerId,from:currentUserId,offer,groupId});
}

