<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/navbar', { currentPage: 'profile' }) %>

    <div class="main-container">
        <%- include('partials/sidebar', { currentPage: 'profile' }) %>

        <main class="feed">

            <% if (success && success.length > 0) { %>
                <div class="alert alert-success">
                    <i class="fa-solid fa-circle-check"></i>
                    <span><%= success[0] %></span>
                </div>
            <% } %>

            <% if (error && error.length > 0) { %>
                <div class="alert alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span><%= error[0] %></span>
                </div>
            <% } %>

            <!-- En-tête du profil -->
            <div class="card profile-header">
                <div class="profile-cover"></div>
                <div class="profile-header-content">
                    <img src="<%= profileUser.photoProfil %>" class="profile-avatar" alt="">
                    <div class="profile-name">
                        <%= profileUser.nom %>
                        <%- include('partials/badges', { badges: profileUser.badges }) %>
                    </div>
                    <% if (profileUser.bio) { %>
                        <div class="profile-bio"><%= profileUser.bio %></div>
                    <% } else { %>
                        <div class="profile-bio" style="opacity:0.5;">Aucune bio renseignée</div>
                    <% } %>

                    <div class="profile-stats">
                        <div class="profile-stat">
                            <strong><%= posts.length %></strong>
                            <span>Publications</span>
                        </div>
                        <div class="profile-stat">
                            <strong><%= profileUser.amis.length %></strong>
                            <span>Amis</span>
                        </div>
                        <% if (!isOwnProfile) { %>
                            <div class="profile-stat">
                                <strong><%= amisCommuns %></strong>
                                <span>En commun</span>
                            </div>
                        <% } %>
                    </div>

                    <div style="margin-top:18px; display:flex; gap:10px; justify-content:center;">
                        <% if (isOwnProfile) { %>
                            <a href="/profile/edit/me" class="btn btn-secondary" style="width:auto; padding:10px 24px;">
                                <i class="fa-solid fa-pen"></i> Modifier le profil
                            </a>
                        <% } else if (isFriend) { %>
                            <form action="/friends/remove/<%= profileUser._id %>" method="POST" style="margin:0;">
                                <button type="submit" class="btn btn-secondary" style="width:auto; padding:10px 24px;">
                                    <i class="fa-solid fa-user-check"></i> Amis
                                </button>
                            </form>
                            <a href="/messages/<%= profileUser._id %>" class="btn" style="width:auto; padding:10px 24px;">
                                <i class="fa-solid fa-comment"></i> Message
                            </a>
                        <% } else if (requestSent) { %>
                            <form action="/friends/cancel/<%= profileUser._id %>" method="POST" style="margin:0;">
                                <button type="submit" class="btn btn-secondary" style="width:auto; padding:10px 24px;">
                                    <i class="fa-solid fa-clock"></i> Annuler la demande
                                </button>
                            </form>
                        <% } else if (requestReceived) { %>
                            <form action="/friends/accept/<%= profileUser._id %>" method="POST" style="margin:0;">
                                <button type="submit" class="btn" style="width:auto; padding:10px 24px;">
                                    <i class="fa-solid fa-check"></i> Accepter la demande
                                </button>
                            </form>
                        <% } else { %>
                            <form action="/friends/request/<%= profileUser._id %>" method="POST" style="margin:0;">
                                <button type="submit" class="btn" style="width:auto; padding:10px 24px;">
                                    <i class="fa-solid fa-user-plus"></i> Ajouter
                                </button>
                            </form>
                        <% } %>
                    </div>
                </div>
            </div>

            <% if (isOwnProfile) { %>
            <div class="card" style="padding:16px 20px; display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap;">
                <div style="display:flex; gap:20px; flex-wrap:wrap;">
                    <div style="display:flex; flex-direction:column; align-items:center; gap:2px;">
                        <span style="font-size:20px;">💰</span>
                        <span style="font-size:17px; font-weight:700; color:#f59e0b;">
                            <% if (profileUser.role === 'admin') { %>∞<% } else { %><%= profileUser.walletBalance || 0 %><% } %>
                        </span>
                        <span style="font-size:11px; color:var(--text-secondary);"><%= profileUser.role === 'admin' ? 'Illimité' : 'Crédits' %></span>
                    </div>
                    <div style="display:flex; flex-direction:column; align-items:center; gap:2px;">
                        <span style="font-size:20px;">⭐</span>
                        <span style="font-size:17px; font-weight:700; color:#8b5cf6;"><%= profileUser.xp || 0 %></span>
                        <span style="font-size:11px; color:var(--text-secondary);">XP</span>
                    </div>
                </div>
                <div style="display:flex; gap:8px; flex-wrap:wrap;">
                    <a href="/wallet" class="btn btn-secondary" style="width:auto; padding:8px 18px; font-size:13px;">
                        <i class="fa-solid fa-wallet"></i> Portefeuille
                    </a>
                    <a href="/shop" class="btn" style="width:auto; padding:8px 18px; font-size:13px;">
                        <i class="fa-solid fa-store"></i> Boutique
                    </a>
                    <button id="cloneToggleBtn" style="padding:8px 18px;font-size:13px;border:1px solid var(--border);border-radius:8px;cursor:pointer;background:<%= profileUser.aiCloneActive ? '#8b5cf6' : 'var(--bg-secondary)' %>;color:<%= profileUser.aiCloneActive ? '#fff' : 'var(--text-primary)' %>;" title="Si activé, un clone IA répond automatiquement à tes messages privés en ton absence">
                        🎭 Clone IA <%= profileUser.aiCloneActive ? '(Actif)' : '(Inactif)' %>
                    </button>
                </div>
            </div>

            <!-- Clone IA - Instructions -->
            <div class="card" id="cloneInstructionsCard" style="padding:16px 20px; display:<%= profileUser.aiCloneActive ? 'block' : 'none' %>;">
                <div style="display:flex; align-items:center; gap:10px; margin-bottom:12px;">
                    <span style="font-size:20px;">🎭</span>
                    <div>
                        <div style="font-weight:700; font-size:14px;">Instructions du Clone IA</div>
                        <div style="font-size:12px; color:var(--text-secondary);">Donne des consignes précises à ton clone pour qu'il réponde à ta façon</div>
                    </div>
                </div>
                <textarea id="cloneInstructionsInput" maxlength="500" rows="3" placeholder="Ex : Réponds de façon détendue et ajoute des emojis. Si on te demande où je suis, dis que je suis occupé mais que je reviens bientôt. Ne révèle jamais d'informations personnelles." style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-size:13px;background:var(--bg-secondary);color:var(--text-primary);resize:vertical;box-sizing:border-box;font-family:inherit;"><%= profileUser.aiCloneInstructions || '' %></textarea>
                <div style="display:flex; justify-content:space-between; align-items:center; margin-top:8px;">
                    <span id="cloneInstrCount" style="font-size:11px; color:var(--text-secondary);"><%= (profileUser.aiCloneInstructions || '').length %>/500</span>
                    <button id="saveCloneInstructions" class="btn" style="width:auto; padding:7px 18px; font-size:13px;">Enregistrer</button>
                </div>
            </div>
            <% } %>

            <!-- Publications -->
            <% if (posts.length === 0) { %>
                <div class="card empty-state">
                    <i class="fa-solid fa-newspaper"></i>
                    <p>Aucune publication pour le moment.</p>
                </div>
            <% } %>

            <% posts.forEach(post => { %>
                <div class="card post">
                    <div class="post-header">
                        <img src="<%= post.auteur.photoProfil %>" class="post-avatar" alt="">
                        <div>
                            <div class="post-author">
                                <%= post.auteur.nom %>
                                <%- include('partials/badges', { badges: post.auteur.badges }) %>
                            </div>
                            <div class="post-date">
                                <%= new Date(post.createdAt).toLocaleString('fr-FR', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
                            </div>
                        </div>
                    </div>

                    <div class="post-content"><%= post.contenu %></div>

                    <% if (post.image) { %>
                        <img src="<%= post.image %>" class="post-image" alt="">
                    <% } %>

                    <div class="post-actions">
                        <button class="like-btn <%= post.likes.some(id => id.toString() === currentUserId) ? 'liked' : '' %>"
                                data-id="<%= post._id %>">
                            <i class="fa-solid fa-thumbs-up"></i>
                            <span class="likes-count"><%= post.likes.length %></span> J'aime
                        </button>

                        <button onclick="toggleComments('<%= post._id %>')">
                            <i class="fa-solid fa-comment"></i>
                            <span class="comments-count"><%= post.commentaires.length %></span> Commentaires
                        </button>

                        <% if (post.auteur._id.toString() === currentUserId) { %>
                            <form action="/post/<%= post._id %>/delete" method="POST" onsubmit="return confirm('Supprimer ce post ?')">
                                <button type="submit">
                                    <i class="fa-solid fa-trash"></i>
                                    Supprimer
                                </button>
                            </form>
                        <% } %>
                    </div>

                    <div class="comments-section" id="comments-<%= post._id %>" style="display:none;">
                        <div class="comments-list">
                            <% post.commentaires.forEach(comment => { %>
                                <div class="comment">
                                    <img src="<%= comment.auteur.photoProfil %>" class="comment-avatar" alt="">
                                    <div class="comment-bubble">
                                        <div class="comment-author">
                                            <%= comment.auteur.nom %>
                                            <%- include('partials/badges', { badges: comment.auteur.badges }) %>
                                        </div>
                                        <div><%= comment.texte %></div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>

                        <form class="comment-form ajax-comment-form" data-id="<%= post._id %>">
                            <input type="text" name="texte" placeholder="Écrire un commentaire..." required>
                            <button type="submit">
                                <i class="fa-solid fa-paper-plane"></i>
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>

        </main>

        <aside class="right-sidebar">
            <h3 style="margin-bottom:12px; font-size:14px; color:var(--text-secondary);">INFORMATIONS</h3>
            <p style="font-size:13px; color:var(--text-secondary); line-height:1.8;">
                <i class="fa-solid fa-calendar"></i> Membre depuis <%= new Date(profileUser.createdAt).toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' }) %><br>
                <i class="fa-solid <%= profileUser.enLigne ? 'fa-circle' : 'fa-circle-o' %>" style="color: <%= profileUser.enLigne ? '#16a34a' : '#94a3b8' %>"></i>
                <%= profileUser.enLigne ? 'En ligne' : 'Hors ligne' %>
            </p>
        </aside>
    </div>

    <script src="/js/feed.js"></script>
    <script>
        function toggleComments(postId) {
            const el = document.getElementById('comments-' + postId)
            el.style.display = el.style.display === 'none' ? 'block' : 'none'
        }

        const cloneBtn = document.getElementById("cloneToggleBtn")
        const cloneCard = document.getElementById("cloneInstructionsCard")
        if (cloneBtn) {
            cloneBtn.addEventListener("click", async () => {
                cloneBtn.disabled = true
                const res = await fetch("/api/clone/toggle", { method: "POST" })
                const data = await res.json()
                cloneBtn.disabled = false
                if (data.success) {
                    cloneBtn.style.background = data.active ? "#8b5cf6" : "var(--bg-secondary)"
                    cloneBtn.style.color = data.active ? "#fff" : "var(--text-primary)"
                    cloneBtn.textContent = `🎭 Clone IA (${data.active ? "Actif" : "Inactif"})`
                    if (cloneCard) cloneCard.style.display = data.active ? "block" : "none"
                }
            })
        }

        const saveCloneBtn = document.getElementById("saveCloneInstructions")
        const instrInput = document.getElementById("cloneInstructionsInput")
        const instrCount = document.getElementById("cloneInstrCount")
        if (instrInput && instrCount) {
            instrInput.addEventListener("input", () => {
                instrCount.textContent = instrInput.value.length + "/500"
            })
        }
        if (saveCloneBtn && instrInput) {
            saveCloneBtn.addEventListener("click", async () => {
                saveCloneBtn.disabled = true
                saveCloneBtn.textContent = "Enregistrement…"
                try {
                    const res = await fetch("/api/clone/instructions", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ instructions: instrInput.value })
                    })
                    const data = await res.json()
                    saveCloneBtn.textContent = data.success ? "✓ Enregistré !" : "Erreur"
                    setTimeout(() => { saveCloneBtn.disabled = false; saveCloneBtn.textContent = "Enregistrer" }, 2000)
                } catch(e) {
                    saveCloneBtn.disabled = false
                    saveCloneBtn.textContent = "Erreur réseau"
                }
            })
        }
    </script>
</body>
</html>