<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/navbar', { currentPage: 'messages' }) %>

    <div class="main-container">
        <%- include('partials/sidebar', { currentPage: 'messages' }) %>

        <main class="feed">

            <div class="page-header">
                <div>
                    <h1>⏳ Salon Éphémère</h1>
                    <div class="subtitle">Un espace de discussion temporaire qui s'auto-détruit</div>
                </div>
                <a href="/messages" class="btn btn-secondary" style="width:auto; padding:10px 20px;">
                    <i class="fa-solid fa-arrow-left"></i> Retour
                </a>
            </div>

            <div id="errorBox" class="alert alert-error" style="display:none;">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span id="errorText"></span>
            </div>

            <div class="card" style="padding:24px;">
                <div style="background:linear-gradient(135deg,#f59e0b22,#ef444422);border:1px solid #f59e0b44;border-radius:12px;padding:14px 18px;margin-bottom:24px;display:flex;gap:12px;align-items:center;">
                    <span style="font-size:28px;">⏳</span>
                    <div>
                        <div style="font-weight:700;font-size:14px;color:#f59e0b;">Salon temporaire</div>
                        <div style="font-size:12px;color:var(--text-secondary);">Ce salon et tous ses messages seront automatiquement supprimés à l'expiration. Parfait pour des discussions ponctuelles confidentielles.</div>
                    </div>
                </div>

                <form id="salonForm">

                    <div class="form-group">
                        <label>Nom du salon</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-fire"></i>
                            <input type="text" name="nom" placeholder="Ex : Planning surprise, Réunion rapide…" required maxlength="50">
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Durée d'expiration</label>
                        <select name="dureeHeures" id="dureeSelect" style="width:100%;padding:12px 16px;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:14px;background:var(--bg-secondary);color:var(--text-primary);cursor:pointer;">
                            <option value="1">1 heure</option>
                            <option value="3">3 heures</option>
                            <option value="6">6 heures</option>
                            <option value="12">12 heures</option>
                            <option value="24" selected>24 heures (1 jour)</option>
                            <option value="48">48 heures (2 jours)</option>
                            <option value="72">72 heures (3 jours)</option>
                            <option value="168">7 jours (max)</option>
                        </select>
                        <div id="expiryPreview" style="font-size:12px;color:var(--text-secondary);margin-top:6px;">⏰ Expiration : <strong id="expiryDate"></strong></div>
                    </div>

                    <div class="form-group">
                        <label>Inviter des amis</label>

                        <% if (amis.length === 0) { %>
                            <div class="empty-state" style="padding:24px;">
                                <i class="fa-solid fa-user-group"></i>
                                <p>Tu n'as pas encore d'amis à ajouter.</p>
                            </div>
                        <% } else { %>
                            <div class="search-bar" style="margin-bottom:12px;">
                                <i class="fa-solid fa-magnifying-glass"></i>
                                <input type="text" id="searchAmis" placeholder="Rechercher un ami...">
                            </div>

                            <div id="amisList" style="max-height:280px; overflow-y:auto; border:1.5px solid var(--border); border-radius:var(--radius-sm);">
                                <% amis.forEach(ami => { %>
                                    <label class="ami-select-item" data-name="<%= ami.nom.toLowerCase() %>">
                                        <div class="user-item" style="padding:12px 16px; cursor:pointer;">
                                            <img src="<%= ami.photoProfil %>" alt="">
                                            <div class="user-item-info">
                                                <div class="user-item-name"><%= ami.nom %></div>
                                                <div class="user-item-sub">
                                                    <span class="online-dot <%= ami.enLigne ? 'online' : 'offline' %>"></span>
                                                    <%= ami.enLigne ? 'En ligne' : 'Hors ligne' %>
                                                </div>
                                            </div>
                                            <input type="checkbox" name="membres" value="<%= ami._id %>"
                                                   style="width:20px; height:20px; accent-color:var(--primary); cursor:pointer;">
                                        </div>
                                    </label>
                                <% }) %>
                            </div>

                            <div id="selectedCount" style="font-size:13px; color:var(--text-secondary); margin-top:8px;">
                                0 ami(s) sélectionné(s)
                            </div>
                        <% } %>
                    </div>

                    <button type="submit" class="btn" id="submitBtn" style="margin-top:8px;">
                        <i class="fa-solid fa-fire"></i> Créer le salon éphémère
                    </button>
                </form>
            </div>
        </main>
    </div>

    <script>
        function updateExpiryPreview() {
            const heures = parseInt(document.getElementById("dureeSelect").value) || 24
            const date = new Date(Date.now() + heures * 3600 * 1000)
            document.getElementById("expiryDate").textContent = date.toLocaleString("fr-FR", {
                day: "numeric", month: "long", year: "numeric",
                hour: "2-digit", minute: "2-digit"
            })
        }
        document.getElementById("dureeSelect").addEventListener("change", updateExpiryPreview)
        updateExpiryPreview()

        const searchAmis = document.getElementById("searchAmis")
        if (searchAmis) {
            searchAmis.addEventListener("input", function() {
                const q = this.value.toLowerCase().trim()
                document.querySelectorAll(".ami-select-item").forEach(item => {
                    item.style.display = item.getAttribute("data-name").includes(q) ? "block" : "none"
                })
            })
        }

        document.querySelectorAll("input[name='membres']").forEach(cb => {
            cb.addEventListener("change", () => {
                const count = document.querySelectorAll("input[name='membres']:checked").length
                document.getElementById("selectedCount").innerText = `${count} ami(s) sélectionné(s)`
            })
        })

        document.getElementById("salonForm").addEventListener("submit", async (e) => {
            e.preventDefault()
            const form = e.target
            const submitBtn = document.getElementById("submitBtn")
            const errorBox = document.getElementById("errorBox")
            const errorText = document.getElementById("errorText")

            const nom = form.nom.value.trim()
            const dureeHeures = document.getElementById("dureeSelect").value
            const membres = [...form.querySelectorAll("input[name='membres']:checked")].map(cb => cb.value)

            if (!nom) {
                errorText.innerText = "Le nom du salon est requis."
                errorBox.style.display = "flex"
                return
            }

            submitBtn.disabled = true
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Création...'
            errorBox.style.display = "none"

            try {
                const res = await fetch("/salons/new", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ nom, membres, dureeHeures })
                })
                const data = await res.json()
                if (data.success) {
                    window.location.href = "/groups/" + data.groupId
                } else {
                    errorText.innerText = data.error || "Erreur lors de la création."
                    errorBox.style.display = "flex"
                    submitBtn.disabled = false
                    submitBtn.innerHTML = '<i class="fa-solid fa-fire"></i> Créer le salon éphémère'
                }
            } catch (err) {
                errorText.innerText = "Erreur de connexion."
                errorBox.style.display = "flex"
                submitBtn.disabled = false
                submitBtn.innerHTML = '<i class="fa-solid fa-fire"></i> Créer le salon éphémère'
            }
        })
    </script>
</body>
</html>
